# --- APP CONFIGURATION ---
# development, production, or test
NODE_ENV=development
# Public environment variable for client-side logic
NEXT_PUBLIC_ENV=development

# --- DATABASE (Prisma/PostgreSQL) ---
# Main connection string for Prisma (usually includes pooling)
DATABASE_URL=
# Used for direct database migrations (e.g., Prisma Migrate)
DIRECT_URL=

# --- ANALYTICS & PUBLIC INFO ---
# Google Analytics Measurement ID (starts with G-)
NEXT_PUBLIC_GA_ID=
# The email displayed publicly on the site
NEXT_PUBLIC_AUTHOR_EMAIL=

# --- AUTHENTICATION (Auth.js / NextAuth) ---
# Base URL of the app (must match your deployment URL in production)
AUTH_URL=http://localhost:3000
# High-entropy random string for encrypting cookies (generate via 'openssl rand -base64 32')
AUTH_SECRET=

# --- EMAIL SERVICE (SMTP / Nodemailer) ---
# SMTP Server (e.g., smtp.gmail.com or smtp.resend.com)
EMAIL_SERVER_HOST=smtp.gmail.com
# Port (587 for TLS, 465 for SSL)
EMAIL_SERVER_PORT=587
# The username for your SMTP service
EMAIL_SERVER_USER=
# App password (for Gmail, use a 16-character App Password)
EMAIL_SERVER_PASSWORD=
# The 'From' address that users will see in their inbox
EMAIL_FROM=

# --- STORAGE (Supabase S3 / Image Uploads) ---
# S3 Region (e.g., ap-northeast-1 for Tokyo)
SUPABASE_S3_STORAGE_REGION=ap-northeast-1
# S3 API Endpoint for uploads (found in Supabase Settings > Storage)
SUPABASE_S3_STORAGE_ENDPOINT=
# Public URL used to serve/display the images in the browser
SUPABASE_S3_STORAGE_PUBLIC_ENDPOINT=
# S3 Access Key (Project API Key)
SUPABASE_S3_STORAGE_ACCESS_KEY=
# S3 Secret Key
SUPABASE_S3_STORAGE_SECRET_KEY=
# The specific bucket name in your Supabase storage
SUPABASE_S3_STORAGE_BUCKET=byte-of-me

# --- BUSINESS LOGIC / ADMIN ---
# Primary admin/author email
EMAIL=
# The UUID of the author in the database (used for filtering public content)
AUTHOR_ID=

# Auth for users
# https://authjs.dev/guides/configuring-github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
