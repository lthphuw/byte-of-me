generator client {
  provider               = "prisma-client"
  output                 = "../generated/prisma"
  importFileExtension    = "ts"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

// ===============================
// AUTHENTICATION (Authjs)
// ===============================
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ===============================
// USER
// ===============================

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  role String @default("USER")

  // NextAuth
  email         String    @unique
  emailVerified DateTime? @map("email_verified")

  accounts Account[]
  sessions Session[]

  // Relations
  userProfile       UserProfile?
  socialLinks       SocialLink[]
  blogs             Blog[]
  educations        Education[]
  workExperiences   Company[]
  projects          Project[]
  techStacks        TechStack[]
  media             Media[]
  interactions      Interaction[]
  comments          Comment[]
  contactMessages   ContactMessage[]
  pageViews         PageView[]
  blogStatisticLogs BlogStatisticLog[]

  @@map("users")
}

model SocialLink {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  platform  String
  url       String
  sortOrder Int    @default(0) @map("sort_order")

  // mediaId String? @map("media_id")
  // image   Media?  @relation(fields: [mediaId], references: [id])

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, platform])
  @@map("social_links")
}

model UserProfile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  birthdate DateTime? @map("birthdate")

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  translations UserProfileTranslation[]

  @@map("user_profiles")
}

model UserProfileTranslation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  language String

  displayName String? @map("display_name")
  firstName   String? @map("first_name")
  middleName  String? @map("middle_name")
  lastName    String? @map("last_name")
  greeting    String? @db.Text
  tagLine     String? @map("tag_line") @db.Text
  quote       String? @db.Text
  quoteAuthor String? @map("quote_author")
  bio         String? @db.Text
  aboutMe     String? @map("about_me") @db.Text

  userProfileId String      @map("user_profile_id")
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@unique([userProfileId, language])
  @@map("user_profile_translations")
}

// ===============================
// EDUCATION
// ===============================

model Education {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sortOrder Int
  startDate DateTime  @map("start_date")
  endDate   DateTime? @map("end_date")

  logoId String? @map("logo_id")
  logo   Media?  @relation(fields: [logoId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  achievements EducationAchievement[]
  translations EducationTranslation[]

  @@index([userId], map: "idx_educations_user_id")
  @@map("educations")
}

model EducationTranslation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  language String

  title       String
  description String? @db.Text

  educationId String    @map("education_id")
  education   Education @relation(fields: [educationId], references: [id], onDelete: Cascade)

  @@unique([educationId, language])
  @@map("education_translations")
}

model EducationAchievement {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sortOrder Int @default(0) @map("sort_order")

  educationId String    @map("education_id")
  education   Education @relation(fields: [educationId], references: [id], onDelete: Cascade)

  translations EducationAchievementTranslation[]
  images       AchievementOnMedias[]

  @@index([educationId], map: "idx_education_achievement_education_id")
  @@map("education_achievements")
}

model EducationAchievementTranslation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  language String

  title   String
  content String? @db.Text

  educationAchievementId String               @map("education_achievement_id")
  educationAchievement   EducationAchievement @relation(fields: [educationAchievementId], references: [id], onDelete: Cascade)

  @@unique([educationAchievementId, language])
  @@map("education_achievement_translations")
}

model AchievementOnMedias {
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  mediaId String @map("media_id")
  media   Media  @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  educationAchievementId String               @map("education_achievement_id")
  educationAchievement   EducationAchievement @relation(fields: [educationAchievementId], references: [id], onDelete: Cascade)

  @@id([educationAchievementId, mediaId])
  @@index([mediaId], map: "idx_achievement_medias")
  @@map("achievement_medias")
}

// ===============================
// TECH STACKS
// ===============================

model TechStack {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  name      String @unique
  slug      String @unique
  group     String
  sortOrder Int    @default(0) @map("sort_order")

  logoId String? @map("logo_id")
  logo   Media?  @relation(fields: [logoId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projects  TechStackOnProjects[]
  companies TechStackOnCompanies[]

  @@map("tech_stacks")
}

model TechStackOnProjects {
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  techStackId String    @map("tech_stack_id")
  techStack   TechStack @relation(fields: [techStackId], references: [id], onDelete: Cascade)

  @@id([projectId, techStackId])
  @@index([techStackId], map: "idx_project_tech_stacks_tech_stack_id")
  @@map("project_tech_stacks")
}

model TechStackOnCompanies {
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  techStackId String    @map("tech_stack_id")
  techStack   TechStack @relation(fields: [techStackId], references: [id], onDelete: Cascade)

  @@id([techStackId, companyId])
  @@map("company_tech_stacks")
}

// ===============================
// WORK EXPERIENCE
// ===============================

model Company {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company  String
  location String

  startDate DateTime  @map("start_date")
  endDate   DateTime? @map("end_date")

  logoId String? @map("logo_id")
  logo   Media?  @relation(fields: [logoId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  roles      Role[]
  techStacks TechStackOnCompanies[]

  translations CompanyTranslation[]

  @@index([userId], map: "idx_companies_user_id")
  @@map("companies")
}

model CompanyTranslation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  language String

  description String? @db.Text

  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, language])
  @@map("company_translations")
}

model Role {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")

  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  tasks        Task[]
  translations RoleTranslation[]

  @@index([companyId], map: "idx_roles_company_id")
  @@map("roles")
}

model RoleTranslation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  language String

  title       String
  description String? @db.Text

  roleId String @map("role_id")
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, language], map: "uidx_role_translation_role_id_language")
  @@map("role_translations")
}

model Task {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  sortOrder Int      @default(0) @map("sort_order")

  roleId String @map("role_id")
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  translations TaskTranslation[]

  @@index([roleId], map: "idx_tasks_role_id")
  @@map("tasks")
}

model TaskTranslation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  language String

  content String @db.Text

  taskId String @map("task_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, language])
  @@map("task_translations")
}

// ===============================
// PROJECTS & BLOGS
// ===============================

model Project {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  slug        String    @unique
  githubLink  String?   @map("github_link")
  liveLink    String?   @map("live_link")
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  isPublished Boolean   @default(false) @map("is_published")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  translations ProjectTranslation[]
  techStacks   TechStackOnProjects[]
  tags         ProjectTag[]

  blog Blog?

  coauthors    ProjectOnProjectCoAuthor[]
  interactions Interaction[]
  comments     Comment[]
  pageViews    PageView[]

  @@index([userId], map: "idx_projects_user_id")
  @@map("projects")
}

model ProjectTranslation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  language String

  title       String
  description String? @db.Text

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, language])
  @@map("project_translations")
}

model ProjectOnProjectCoAuthor {
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  coauthorId String   @map("coauthor_id")
  coauthor   Coauthor @relation(fields: [coauthorId], references: [id], onDelete: Cascade)

  @@id([projectId, coauthorId])
  @@index([coauthorId], map: "idx_project_coauthor_coauthor_id")
  @@map("project_coauthors")
}

model Coauthor {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  fullName String  @map("full_name")
  email    String?

  projects ProjectOnProjectCoAuthor[]

  @@map("coauthors")
}

model Blog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  slug          String    @unique
  publishedDate DateTime? @default(now()) @map("published_date")
  isPublished   Boolean   @default(false) @map("is_published")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String?  @unique @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  readingTime Int? @map("reading_time")

  coverImageId String? @map("cover_image_id")
  coverImage   Media?  @relation(fields: [coverImageId], references: [id], onDelete: SetNull)

  translations BlogTranslation[]
  tags         BlogTag[]
  interactions Interaction[]
  comments     Comment[]
  pageViews    PageView[]
  blogViewLogs BlogStatisticLog[]

  @@index([userId], map: "idx_blogs_user_id")
  @@index([isPublished, publishedDate(sort: Desc)], map: "idx_blogs_published_feed")
  @@index([isPublished, publishedDate], map: "idx_blogs_publish_scheduler")
  @@map("blogs")
}

model BlogTranslation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  language String

  title       String
  description String? @db.Text
  content     String  @db.Text

  blogId String @map("blog_id")
  blog   Blog   @relation(fields: [blogId], references: [id], onDelete: Cascade)

  @@unique([blogId, language])
  @@map("blog_translations")
}

model BlogStatisticLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  blogId String @map("blog_id")
  blog   Blog   @relation(fields: [blogId], references: [id], onDelete: Cascade)

  readingTime Int? @map("reading_time") // in seconds

  isAnonymous Boolean @default(true) @map("is_anonymous")
  viewerId    String? @map("viewer_id")
  viewer      User?   @relation(fields: [viewerId], references: [id])

  referrer   String? @db.Text
  deviceType String? @map("device_type") // e.g., "mobile", "desktop", "tablet"
  browser    String? // e.g., "Chrome", "Safari"

  countryCode String? @map("country_code") // e.g., "US", "VN", "GB"

  @@index([blogId], map: "idx_blog_view_logs_blog_id")
  @@index([blogId, createdAt(sort: Desc)], map: "idx_blog_logs_time_series")
  @@index([blogId, deviceType], map: "idx_blog_logs_device")
  @@index([blogId, countryCode], map: "idx_blog_logs_country")
  @@map("blog_view_logs")
}

// ===============================
// TAGS
// ===============================

model Tag {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  slug         String           @unique
  translations TagTranslation[]
  blogs        BlogTag[]
  projects     ProjectTag[]

  @@map("tags")
}

model TagTranslation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  language String

  name String @unique

  tagId String @map("tag_id")
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, language])
  @@map("tag_translations")
}

model BlogTag {
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  blogId String @map("blog_id")
  blog   Blog   @relation(fields: [blogId], references: [id], onDelete: Cascade)

  tagId String @map("tag_id")
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([blogId, tagId])
  @@index([tagId], map: "idx_blog_tags_tag_id")
  @@map("blog_tags")
}

model ProjectTag {
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tagId String @map("tag_id")
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([projectId, tagId])
  @@index([tagId], map: "idx_project_tag_tag_id")
  @@map("project_tags")
}

// ===============================
// TRANSLATIONS
// ===============================

model Translation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  language     String
  sourceText   String  @map("source_text") @db.Text
  translated   String  @db.Text
  resourceType String? @map("resource_type")
  resourceId   String? @map("resource_id")

  @@unique([sourceText, language], map: "uq_translations_source_text_language")
  @@index([resourceType, resourceId], map: "idx_translations_resource")
  @@map("translations")
}

// ===============================
// MEDIA
// ===============================

model Media {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  fileName String @map("file_name")
  fileKey  String @unique @map("file_key")
  mimeType String @map("mime_type")
  size     Int
  provider String
  bucket   String
  url      String

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // socialLinks         SocialLink[]
  companies           Company[]
  techStacks          TechStack[]
  education           Education[]
  educationAchiements AchievementOnMedias[]
  blogs               Blog[]

  @@map("media")
}

// ===============================
// INTERACTIONS (Likes, Shares, etc.)
// ===============================

model Interaction {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  // Loại tương tác (VD: "LIKE", "HEART", "CLAP", "SHARE")
  type String

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Tương tác có thể thuộc về Blog hoặc Project
  blogId String? @map("blog_id")
  blog   Blog?   @relation(fields: [blogId], references: [id], onDelete: Cascade)

  projectId String?  @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, blogId, type], map: "uq_user_blog_interaction")
  @@unique([userId, projectId, type], map: "uq_user_project_interaction")
  @@index([blogId], map: "idx_interactions_blog_id")
  @@index([projectId], map: "idx_interactions_project_id")
  @@map("interactions")
}

// ===============================
// COMMENTS
// ===============================
model Comment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  content   String  @db.Text
  isDeleted Boolean @default(false) @map("is_deleted")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Comment có thể thuộc về Blog hoặc Project
  blogId String? @map("blog_id")
  blog   Blog?   @relation(fields: [blogId], references: [id], onDelete: Cascade)

  projectId String?  @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Hỗ trợ Nested Comments (Trả lời comment)
  parentId String?   @map("parent_id")
  parent   Comment?  @relation("CommentToComment", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentToComment")

  @@index([blogId], map: "idx_comments_blog_id")
  @@index([projectId], map: "idx_comments_project_id")
  @@index([parentId], map: "idx_comments_parent_id")
  @@map("comments")
}

// ===============================
// TRAFFIC / ANALYTICS
// ===============================

model PageView {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  path String // URL endpoint (VD: "/projects/my-app", "/blogs/hello-world")

  // Lưu trữ hashed IP hoặc session_id để đếm "Unique Visitors" mà không vi phạm GDPR
  visitorId String? @map("visitor_id")
  userAgent String? @map("user_agent")
  referer   String?

  // Liên kết tùy chọn để dễ dàng query số lượng view của 1 bài cụ thể
  blogId String? @map("blog_id")
  blog   Blog?   @relation(fields: [blogId], references: [id], onDelete: Cascade)

  projectId String?  @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?

  @@index([path], map: "idx_page_views_path")
  @@index([blogId], map: "idx_page_views_blog_id")
  @@index([projectId], map: "idx_page_views_project_id")
  @@map("page_views")
}

// ===============================
// CONTACT
// ===============================
model ContactMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  name    String
  email   String
  subject String?
  message String  @db.Text

  isRead    Boolean @default(false) @map("is_read")
  isReplied Boolean @default(false) @map("is_replied")

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([email], map: "idx_contact_email")
  @@map("contact_messages")
}
