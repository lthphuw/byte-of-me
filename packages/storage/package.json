{
  "name": "@byte-of-me/storage",
  "version": "1.0.0",
  "description": "Lightweight S3-compatible storage client",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "pnpm clean && pnpm build:js && pnpm build:types",
    "build:js": "swc src -d dist --strip-leading-paths",
    "build:types": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "test": "jest",
    "lint": "eslint src --fix",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@aws-sdk/s3-request-presigner": "^3.1009.0"
  },
  "devDependencies": {
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.18",
    "@types/jest": "^29.5.0",
    "@types/node": "^25.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  }
}
